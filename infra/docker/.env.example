# ─── SIMES Docker Environment ─────────────────────────────
# Copy this file to .env and adjust values before deploying.
# ──────────────────────────────────────────────────────────

# --- DB CORE (Postgres)
CORE_DB_NAME=simes_core
CORE_DB_USER=simes
CORE_DB_PASSWORD=simes

# --- DB TELEMETRY (TimescaleDB)
TELEMETRY_DB_NAME=simes_telemetry
TELEMETRY_DB_USER=simes
TELEMETRY_DB_PASSWORD=simes

# --- Redis
REDIS_PASSWORD=simes

# --- MinIO
MINIO_ROOT_USER=simesadmin
MINIO_ROOT_PASSWORD=simesadmin123
MINIO_BUCKET_REPORTS=reports

# --- Timezone
TZ=Africa/Ouagadougou

# --- HTTP Ports (Traefik)
HTTP_PORT=80
HTTPS_PORT=443

# --- Domain (for TLS with Let's Encrypt — uncomment for production)
# DOMAIN=simes.example.com
# ACME_EMAIL=admin@example.com
